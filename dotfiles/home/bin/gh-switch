#!/bin/sh

#
# Switch to a branch from a GitHub fork, adding the remote if needed
#
# USAGE:
#   cd some/repo
#   gh-switch username:branch-name
#

set -eu

case "${1-}" in
	*:?*)
		username=${1%%:*}
		branch=${1#*:}
		;;
	*)
		echo "Usage: gh-switch username:branch-name" >&2
		exit 1
		;;
esac

gh-remote-add "$username"

git switch --track -c "gh/$username/$branch" "$username/$branch"

# The local branch name (gh/username/branch) differs from the remote branch
# name (branch), so git push cannot infer the destination. This refspec
# explicitly maps the local name to the remote name so that plain
# `git push` and `git push --force-with-lease` work without extra arguments.
git config --add "remote.$username.push" \
	"refs/heads/gh/$username/$branch:refs/heads/$branch"
